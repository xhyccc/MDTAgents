# ==============================================================================
# MDTAgents — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
#   cp example.env .env
#
# The .env file is auto-discovered from the project root.  Override the
# location with:   export MDT_ENV_FILE=/path/to/my.env
#
# Lines starting with # are comments.  Values may be quoted with " or '.
# Existing environment variables are NEVER overwritten by this file.
# ==============================================================================


# ------------------------------------------------------------------------------
# Agent backend
# ------------------------------------------------------------------------------
# Which coding-agent CLI to use for LLM calls:
#
#   opencode   (default) — opencode v1.4.3+, https://github.com/sst/opencode
#                          Must be installed and on PATH.  Uses its own config
#                          (~/.config/opencode/config.json) for API keys.
#
#   mini_agent            — mini-coding-agent-CLI, OpenAI-compatible APIs.
#                          https://github.com/xhyccc/mini-coding-agent-CLI
#                          Requires LLM_API_KEY (or a provider-specific key).
#
# Can also be set in config/system.yaml under opencode.backend.
# ------------------------------------------------------------------------------
AGENT_BACKEND=opencode


# ------------------------------------------------------------------------------
# LLM provider  (used by mini_agent backend; opencode uses its own config)
# ------------------------------------------------------------------------------
# Supported values: kimi | moonshot | zhipu | siliconflow | openai | custom
#
# "kimi" and "moonshot" are aliases — both point to https://api.moonshot.cn/v1
# "custom" requires LLM_BASE_URL + LLM_API_KEY + LLM_MODEL to be set below.
# ------------------------------------------------------------------------------
LLM_PROVIDER=kimi


# ------------------------------------------------------------------------------
# API keys — set the one matching your provider
# ------------------------------------------------------------------------------

# Kimi / Moonshot AI  (https://platform.moonshot.cn)
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # alias

# Zhipu AI / GLM  (https://open.bigmodel.cn)
# ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxx

# SiliconFlow  (https://siliconflow.cn)
# SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI  (https://platform.openai.com)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Generic override — takes priority over all provider-specific keys above
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------------------------
# Model selection
# ------------------------------------------------------------------------------
# Leave blank to use the provider default listed below, or set an explicit name.
#
#   kimi / moonshot : moonshot-v1-8k | moonshot-v1-32k | moonshot-v1-128k (default)
#   zhipu           : glm-4 (default) | glm-4-flash | glm-4-long
#   siliconflow     : deepseek-ai/DeepSeek-V3 (default) | Qwen/Qwen2.5-72B-Instruct
#   openai          : gpt-4o (default) | gpt-4o-mini | gpt-4-turbo
# ------------------------------------------------------------------------------
# LLM_MODEL=moonshot-v1-128k


# ------------------------------------------------------------------------------
# Custom provider  (only required when LLM_PROVIDER=custom)
# ------------------------------------------------------------------------------
# LLM_BASE_URL=https://api.example.com/v1
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=your-model-name


# ------------------------------------------------------------------------------
# mini-coding-agent settings  (only used when AGENT_BACKEND=mini_agent)
# ------------------------------------------------------------------------------
# Command used to launch mini-coding-agent.  Options:
#   mini-coding-agent          if installed via: pip install / uv tool install
#   uv run mini-coding-agent   if using uv without a global install
#   python /path/to/mini_coding_agent.py   if using the script directly
# MINI_AGENT_CMD=mini-coding-agent

# Maximum steps (tool calls + model turns) per agent invocation.
# Increase for complex tasks; decrease for faster/cheaper runs.
# MINI_AGENT_MAX_STEPS=15

# OpenAI-compatible API timeout per request (seconds).  Increase for slow APIs.
# MINI_AGENT_OPENAI_TIMEOUT=300

# Maximum tokens to generate per model step.  Medical reports need large values.
# MINI_AGENT_MAX_NEW_TOKENS=8192
